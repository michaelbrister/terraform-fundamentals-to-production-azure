      }
    },
    {
      "address": "azurerm_network_security_group.admin",
      "mode": "managed",
      "type": "azurerm_network_security_group",
      "name": "admin",
      "change": {
        "actions": ["create"],
        "after": {
          "name": "tf-course-prod-admin-nsg",
          "tags": {
            "Environment": "prod",
            "ManagedBy": "terraform",
